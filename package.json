{
  "name": "mediascribe",
  "version": "1.0.2",
  "private": true,
  "description": "Desktop UI for faster-whisper media transcription",
  "author": "Declan Jeon <declanjeon@users.noreply.github.com>",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node scripts/run-tests.cjs",
    "build:web": "next build",
    "build:icons": "node scripts/generate-icons.cjs",
    "clean:dist": "node scripts/clean-dist.cjs",
    "desktop": "electron .",
    "dist": "npm run dist:win",
    "dist:win": "npm run clean:dist && npm run build:icons && npm run build:web && electron-builder --publish never --win portable nsis",
    "dist:portable": "npm run clean:dist && npm run build:icons && npm run build:web && electron-builder --publish never --win portable",
    "dist:installer": "npm run clean:dist && npm run build:icons && npm run build:web && electron-builder --publish never --win nsis",
    "dist:mac": "npm run clean:dist && npm run build:icons && npm run build:web && electron-builder --publish never --mac dmg zip",
    "dist:linux": "npm run clean:dist && npm run build:icons && npm run build:web && electron-builder --publish never --linux AppImage deb",
    "release": "semantic-release"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "semantic-release": "^24.2.7",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.hermes.mediascribe",
    "productName": "MediaScribe",
    "files": [
      "electron/**/*",
      "lib/desktop-utils.cjs",
      "lib/progress-utils.cjs",
      "lib/system-utils.cjs",
      "lib/live-progress.cjs",
      "lib/tagged-output.cjs",
      "out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../WhisperTranscriber",
        "to": "WhisperTranscriber",
        "filter": [
          "**/*",
          "!venv/**/__pycache__/**",
          "!venv/Lib/site-packages/**/*.pyc",
          "!venv/Lib/site-packages/**/__pycache__/**"
        ]
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "MediaScribe-macOS-${arch}.${ext}"
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "MediaScribe-linux-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "MediaScribe-Portable.exe"
    },
    "nsis": {
      "artifactName": "MediaScribe-Setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MediaScribe",
      "language": "1042",
      "displayLanguageSelector": false,
      "warningsAsErrors": false
    }
  }
}
